// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Applicant {
  id          String   @id @default(cuid())
  fullName    String?
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
}
